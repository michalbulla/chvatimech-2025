<div id="page-wrap" class="bg-brand-gray-light">
  {% block headerContent %}
    {% include '_partials/header' %}
  {% endblock %}

  {% block hero %}
    {% include "_partials/heroSub" %}
  {% endblock %}

  {% block intro %}
    {% include "_partials/intro" %}
  {% endblock %}

  <div class="px-4 xl:px-0 xl:container">
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}
      {% endembed %}
    {% endblock %}
  </div>
</div>
{% block footerContent %}
  {% include '_partials/footer' %}
{% endblock %}
