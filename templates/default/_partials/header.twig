<header>
  <div class="bg-brand-gray-light">
    <div class="lg:container px-4">
      <div class="flex items-center justify-between lg:p-4">
        <div class="logo pr-8 lg:pr-0 lg:mx-auto"><a href="/" title="Back to Home Page"><img class="w-[385px] " src="/img/logo.jpg" alt="{{ siteName }}" /></a></div>
        {# {% include '_partials/nav/top' %} #}
        <button type="button" aria-label="Main Navigation Toggle" title="Main Navigation Toggle" aria-haspopup="true" aria-controls="main-nav" aria-expanded="false" class="main-nav-toggle lg:hidden" id="main-nav-toggle">
          {{ svg("@webroot/img/icons/bars-solid.svg")|attr({class: 'h-8 w-8 inline-block text-brand-green'}) }}
        </button>
      </div>
    </div>
  </div>
  <div class="bg-brand-gray-light">
    <div class="lg:container px-4">
      {% include '_partials/nav/main' %}
    </div>
  </div>
</header>
