{% extends "_layouts/base" %}
{% set uri = entry.uri|default('blog') %}
{% set pageHeading = entry.pageHeading|default(entry.title) %}

{% set bodyClass = "home-page" %}

{% set showSidebar = true %}

{% block pageLayout %}
  {% embed '_layouts/page/homePage' %}
    {% block contentLayout %}
      {% embed '_layouts/content/default' %}
        {% block mainContent %}
          <div class="carousel-wrap hp-swiper-top">
            {% include '_partials/carousel' %}
          </div>
          {% cache %}
          <div class="intro-section py-12 bg-white mb-8">
            <div class="lg:container px-4">
              <div class="intro">
                <h1 class="main-heading">Chvatimech - pre každého niečo</h1>
                {{ entry.intro }}
              </div>
            </div>
          </div>
            {% set kategorie = craft.entries.section('pages').level(1) %}
            {% if kategorie|length %}
              <div class="list pt-8">
                <div class="lg:container px-4">
                  {% for kategoria in kategorie %}
                    <div class="pb-8 mb-8 border-b border-brand-green/10 sm-md:grid grid-cols-5 gap-4">
                      <div class="list-image col-span-2 mb-4 sm-md:mb-0">
                        <a href="{{ kategoria.url }}">
                          <img src="{{ kategoria.image.one.url('homePageImage') }}" alt="{{ kategoria.image.title }}">
                        </a>
                      </div>
                      <div class="list-info col-span-3">
                        <h2 class="text-3xl font-secondary text-brand-green mb-4 font-semibold"><a href="{{ kategoria.url }}">{{ kategoria.pageHeading }}</a></h2>
                        <p class="mb-4 text-xl">{{ kategoria.kratkyPopis }}</p>
                        <div class="btn-wrap side-by-side">
                          <a href="{{ kategoria.url }}" class="btn">Čítaj viac</a>
                        </div>
                      </div>
                    </div>
                  {% endfor %}
                </div>
              </div>
            {% endif %}
          {% endcache %}
        {% endblock %}
      {% endembed %}
    {% endblock %}
  {% endembed %}
{% endblock %}
